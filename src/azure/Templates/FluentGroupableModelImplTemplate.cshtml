@using System
@using AutoRest.Java
@using AutoRest.Java.vanilla.Templates
@using AutoRest.Java.azure.Templates
@using System.Linq
@using AutoRest.Core.Utilities
@using AutoRest.Java.Model
@using AutoRest.Java.Azure.Model
@using  AutoRest.Java.Azure.Fluent.Model;
@inherits AutoRest.Core.Template<AutoRest.Java.Azure.Fluent.Model.GroupableFluentModelImpl>
/**
@Header(" * ").TrimMultilineHeader()
 */
@EmptyLine

package @(Settings.Namespace.ToLower()).fluent.implementation;

@EmptyLine

@foreach (var importClass in Model.Imports)
{
@:import @importClass;
}
@EmptyLine

class @(Model.JvaClassName)@(Model.ExtendsFrom)@(Model.Implements) {
@foreach (string declareVariable in Model.DeclareCreateAndUpdateVariables)
{
@:    @declareVariable
}

    @(Model.JvaClassName)() {
@foreach (string initvariable in Model.InitCreateAndUpdateVariables)
{
@:        @initvariable
}
    }

@foreach (FluentDefinitionOrUpdateStageMethod createWither in Model.CreateOnlyWither)
{
@EmptyLine
    var methodSignature = $"{Model.JvaClassName} {createWither.Name}({createWither.ParameterType} {createWither.ParameterName})";
@:    @@Override
@:    public @(methodSignature) {
<text>
        @(Model.CreateParameter).@(createWither.Name)(@(createWither.ParameterName));
        return this;
</text>
@:    }
}

@foreach (FluentDefinitionOrUpdateStageMethod updateWither in Model.UpdateOnlyWithers)
{
@EmptyLine
    var methodSignature = $"{Model.JvaClassName} {updateWither.Name}({updateWither.ParameterType} {updateWither.ParameterName})";
@:    @@Override
@:    public @(methodSignature) {
<text>
        @(Model.UpdateParameter).@(updateWither.Name)(@(updateWither.ParameterName));
        return this;
</text>
@:    }
}

@foreach (FluentDefinitionOrUpdateStageMethod cuWither in Model.CreateAndUpdateWithers)
{
@EmptyLine
    var methodSignature = $"{Model.JvaClassName} {cuWither.Name}({cuWither.ParameterType} {cuWither.ParameterName})";
@:    @@Override
@:    public @(methodSignature) {
@:        @if (Model.IsCreateUpdateTypeSame)
          {
<text>
        @(Model.CreateParameter).@(cuWither.Name)(@(cuWither.ParameterName));
</text>
          }
          else
          {
<text>
        if (isInCreateModel()) {
            @(Model.CreateParameter).@(cuWither.Name)(@(cuWither.ParameterName));
        } else {
            @(Model.UpdateParameter).@(cuWither.Name)(@(cuWither.ParameterName));
        }
</text>
          }
@:        return this;
@:    }
}
}